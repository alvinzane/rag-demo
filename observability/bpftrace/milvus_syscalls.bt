#!/usr/bin/env bpftrace

tracepoint:raw_syscalls:sys_enter
/comm == "milvus"/
{
  @syscall_start[tid, args->id] = nsecs;
}

tracepoint:raw_syscalls:sys_exit
/comm == "milvus" && @syscall_start[tid, args->id]/
{
  @syscall_latency_us[args->id] = hist((nsecs - @syscall_start[tid, args->id]) / 1000);
  delete(@syscall_start[tid, args->id]);
}

interval:s:5
{
  printf("\nsyscall latency in us\n");
  print(@syscall_latency_us);
  clear(@syscall_latency_us);
}
